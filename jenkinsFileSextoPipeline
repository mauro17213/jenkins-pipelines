pipeline {
    agent { label 'windows' }   

    triggers {
        githubPush()
    }

    tools {
        // Maven debe estar configurado en Jenkins (Global Tool Configuration)
        maven 'MAVEN_HOME'
        jdk 'JDK11'   // o la versión que uses en WildFly
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Obteniendo código desde GitHub..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "🔨 Compilando y empaquetando con Maven..."
                bat 'mvn clean package -DskipTests'
            }
        }

        stage('Archive') {
            steps {
                echo "💾 Guardando artefacto en Jenkins..."
                archiveArtifacts artifacts: 'target/*.war', fingerprint: true
            }
        }

        stage('Deploy to WildFly') {
            steps {
                echo "🚀 Desplegando en WildFly..."
                // Copia el WAR al directorio de despliegue de WildFly
                bat 'copy target\\*.war C:\\wildfly-9.1.0.Final\\standalone\\deployments\\'
            }
        }
    }
}
