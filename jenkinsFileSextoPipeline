pipeline {
    agent { label 'windows' }   

    // Ejecuta el pipeline cuando GitHub envíe un webhook
    triggers {
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Obteniendo código desde GitHub..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "📦 Generando artefacto ZIP..."
                powershell '''
                    $zipPath = "artefacto.zip"
                    if (Test-Path $zipPath) { Remove-Item $zipPath }
                    Compress-Archive -Path * -DestinationPath $zipPath -Force
                '''
            }
        }

        stage('Archive') {
            steps {
                echo "💾 Guardando artefacto en Jenkins..."
                archiveArtifacts artifacts: 'artefacto.zip', fingerprint: true
            }
        }
    }
}
