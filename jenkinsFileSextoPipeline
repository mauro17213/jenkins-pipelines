pipeline {
    agent any

    triggers {
        // Escucha cambios desde GitHub mediante Webhook
        githubPush()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "Obteniendo código desde GitHub..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "Generando artefacto ZIP..."
                // Elimina artefactos antiguos
                sh 'rm -f artefacto.zip'

                // Empaqueta todo el proyecto en ZIP
                sh 'zip -r artefacto.zip ./*'
            }
        }

        stage('Archive') {
            steps {
                echo "Guardando artefacto en Jenkins..."
                // Guarda el ZIP como artefacto del job
                archiveArtifacts artifacts: 'artefacto.zip', fingerprint: true
            }
        }
    }
}

